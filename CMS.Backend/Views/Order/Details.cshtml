@model CMS.Data.Entities.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Chi tiết Đơn hàng #@Model.Id</h6>
        <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-body">
        <div class="row mb-4">
            <div class="col-md-6">
                <h5 class="font-weight-bold text-dark">Thông tin người đặt</h5>
                <p class="mb-1"><strong>Họ tên:</strong> @Model.Customer?.FullName</p>
                <p class="mb-1"><strong>Email:</strong> @Model.Customer?.Email</p>
                <p class="mb-1"><strong>SĐT gốc:</strong> @Model.Customer?.Phone</p>
            </div>
            <div class="col-md-6">
                <h5 class="font-weight-bold text-dark">Thông tin giao hàng (từ Ghi chú)</h5>
                <p class="mb-1"><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                <div class="alert alert-info p-2 mt-2">
                    @Html.Raw(Model.Notes?.Replace("\n", "<br/>") ?? "Không có ghi chú")
                </div>
            </div>
        </div>

        <h5 class="font-weight-bold text-dark mb-3">Danh sách sản phẩm</h5>
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead class="bg-light">
                    <tr>
                        <th>ID Sản phẩm</th>
                        <th>Tên sản phẩm</th>
                        <th>Hình ảnh</th>
                        <th>Đơn giá</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                    {
                        decimal totalSum = 0;
                        foreach (var item in Model.OrderDetails)
                        {
                            decimal lineTotal = item.UnitPrice * item.Quantity;
                            totalSum += lineTotal;
                            <tr>
                                <td>@item.ProductId</td>
                                <td>@(item.Product != null ? item.Product.Name : "Sản phẩm đã xóa")</td>
                                <td>
                                    @if (item.Product != null && !string.IsNullOrEmpty(item.Product.ImageUrl))
                                    {
                                        <img src="@item.Product.ImageUrl" width="50" height="50" style="object-fit:cover" />
                                    }
                                </td>
                                <td>@item.UnitPrice.ToString("N0") VNĐ</td>
                                <td>@item.Quantity</td>
                                <td>@lineTotal.ToString("N0") VNĐ</td>
                            </tr>
                        }
                        <tr>
                            <td colspan="5" class="text-right font-weight-bold text-danger h5">Tổng cộng:</td>
                            <td class="font-weight-bold text-danger h5">@totalSum.ToString("N0") VNĐ</td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">Chưa có sản phẩm nào</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
