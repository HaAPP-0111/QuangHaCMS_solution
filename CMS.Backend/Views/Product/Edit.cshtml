@{
    Layout = "_LayoutAdmin";
}
@model CMS.Data.Entities.Product

<h2 class="text-primary">SỬA THÔNG TIN SẢN PHẨM</h2>
<hr />

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        <div class="col-md-8">
            <div class="mb-3">
                <label class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả sản phẩm</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                    <input asp-for="Price" class="form-control" type="number" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Số lượng tồn kho</label>
                    <input asp-for="StockQuantity" class="form-control" type="number" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Đường dẫn hình ảnh</label>
                <input asp-for="ImageUrl" class="form-control" />
                <small class="text-muted">Nhập đường dẫn tương đối tới ảnh trong thư mục wwwroot</small>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-3">
                    <label class="form-label fw-bold">Ảnh hiện tại:</label><br />
                    <img src="@Model.ImageUrl" alt="@Model.Name" style="width:120px; height:120px; object-fit:cover; border-radius:8px; border:1px solid #ddd;" />
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-bold">Danh mục sản phẩm <span class="text-danger">*</span></label>
                <select asp-for="CategoryProductId" asp-items="ViewBag.CategoryList" class="form-select">
                    <option value="">-- Chọn danh mục --</option>
                </select>
            </div>

            <button type="submit" class="btn btn-warning px-4">
                <i class="bi bi-pencil-square"></i> Cập nhật
            </button>
            <a asp-action="Index" class="btn btn-secondary px-4 ms-2">Quay lại</a>
        </div>
    </div>
</form>
