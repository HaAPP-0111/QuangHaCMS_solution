@{
    Layout = "_LayoutAdmin";
}
@model IEnumerable<CMS.Data.Entities.Product>

<h2 class="text-primary">QUẢN LÝ SẢN PHẨM THÚ CƯNG</h2>
<a asp-action="Create" class="btn btn-success mb-3">
    <i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
</a>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th style="width:80px">Hình ảnh</th>
            <th>Tên sản phẩm</th>
            <th>Danh mục</th>
            <th>Giá (VNĐ)</th>
            <th>Tồn kho</th>
            <th style="width:150px">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Name" style="width:60px; height:60px; object-fit:cover; border-radius:6px;" />
                    }
                    else
                    {
                        <span class="text-muted">Chưa có ảnh</span>
                    }
                </td>
                <td>@item.Name</td>
                <td>@(item.CategoryProduct != null ? item.CategoryProduct.Name : "Chưa phân loại")</td>
                <td class="text-danger fw-bold">@item.Price.ToString("N0") ₫</td>
                <td>
                    @if (item.StockQuantity <= 5)
                    {
                        <span class="badge bg-danger">@item.StockQuantity</span>
                    }
                    else
                    {
                        <span class="badge bg-success">@item.StockQuantity</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-warning">Sửa</a>

                    <a asp-action="Delete" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
