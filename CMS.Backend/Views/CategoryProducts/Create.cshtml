@{
    Layout = "_LayoutAdmin";
}
@model CMS.Data.Entities.CategoryProduct

<h2 class="text-primary">THÊM DANH MỤC SẢN PHẨM MỚI</h2>
<hr />

<form action="/CategoryProducts/Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="VD: Thức ăn cho chó" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả danh mục..."></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Link Ảnh đại diện (ImageUrl)</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
            </div>

            <button type="submit" class="btn btn-success px-4">
                <i class="bi bi-check-circle"></i> Lưu danh mục
            </button>
            <a href="/CategoryProducts" class="btn btn-secondary px-4 ms-2">Quay lại</a>
        </div>
    </div>
</form>
