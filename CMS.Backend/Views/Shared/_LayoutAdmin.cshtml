<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThaiCMS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
            .sidebar {
                min-height: 100vh;
                background-color: #212529;
                color: white;
            }

                .sidebar a {
                    color: #adb5bd;
                    text-decoration: none;
                    display: block;
                    padding: 10px 20px;
                }

                    .sidebar a:hover {
                        background-color: #343a40;
                        color: white;
                    }

                .sidebar .active {
                    background-color: #0d6efd;
                    color: white;
                }

            /* Tối ưu thêm phần Topbar bên phải */
            .topbar {
                background-color: #f8f9fa;
                border-bottom: 1px solid #dee2e6;
                padding: 12px 24px;
            }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 sidebar p-0">
                <div class="p-3 text-center border-bottom border-secondary">
                    <h4 class="text-white">ThaiCMS Admin</h4>
                </div>
                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Bảng điều khiển
                    </a>
                    <a asp-controller="Category" asp-action="Index">
                        <i class="bi bi-grid"></i> Quản lý Danh mục
                    </a>
                    <a asp-controller="Post" asp-action="Index">
                        <i class="bi bi-file-earmark-post"></i> Quản lý Bài viết
                    </a>

                    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                    {
                        <a asp-controller="User" asp-action="Index">
                            <i class="bi bi-people"></i> Quản lý Thành viên
                        </a>
                    }

                    <a asp-controller="ProductCategory" asp-action="Index">
                        <i class="bi bi-grid"></i> Danh mục sản phẩm
                    </a>
                    <a asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box-seam"></i> Sản phẩm
                    </a>
                    <a asp-controller="Customer" asp-action="Index">
                        <i class="bi bi-people"></i> Khách hàng
                    </a>
                    <a asp-controller="Order" asp-action="Index">
                        <i class="bi bi-grid"></i> Đơn hàng
                    </a>
                    <a asp-controller="OrderDetail" asp-action="Index">
                        <i class="bi bi-grid"></i> Đơn hàng chi tiết
                    </a>
                </div>
            </nav>

            <div class="col-md-9 col-lg-10 ms-sm-auto p-0">

                <header class="topbar d-flex justify-content-between align-items-center">
                    <div class="text-secondary breadcrumb m-0">
                        <span>Hệ thống quản trị</span>
                    </div>

                    <ul class="navbar-nav flex-row gap-3 align-items-center m-0">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="text-dark">
                                    Chào, <strong>@User.FindFirst("FullName")?.Value</strong>
                                    <span class="badge bg-secondary">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                        }
                    </ul>
                </header>

                <main class="p-4">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>