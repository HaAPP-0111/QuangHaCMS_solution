@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Bảng điều khiển";
}

<!-- Thống kê tổng quan -->
<h2 class="text-primary mb-4"><i class="bi bi-speedometer2"></i> BẢNG ĐIỀU KHIỂN</h2>

<div class="row g-4 mb-4">
    <!-- Card: Sản phẩm -->
    <div class="col-md-4 col-lg-2">
        <div class="card text-center" style="border-left: 4px solid #3b82f6 !important;">
            <div class="card-body py-3">
                <i class="bi bi-box-seam-fill text-primary" style="font-size: 2rem;"></i>
                <h3 class="fw-bold mt-2 mb-0">@ViewBag.TotalProducts</h3>
                <small class="text-muted">Sản phẩm</small>
            </div>
        </div>
    </div>

    <!-- Card: Danh mục SP -->
    <div class="col-md-4 col-lg-2">
        <div class="card text-center" style="border-left: 4px solid #10b981 !important;">
            <div class="card-body py-3">
                <i class="bi bi-grid-3x3-gap-fill text-success" style="font-size: 2rem;"></i>
                <h3 class="fw-bold mt-2 mb-0">@ViewBag.TotalCategoryProducts</h3>
                <small class="text-muted">Danh mục SP</small>
            </div>
        </div>
    </div>

    <!-- Card: Bài viết -->
    <div class="col-md-4 col-lg-2">
        <div class="card text-center" style="border-left: 4px solid #f59e0b !important;">
            <div class="card-body py-3">
                <i class="bi bi-file-earmark-post-fill text-warning" style="font-size: 2rem;"></i>
                <h3 class="fw-bold mt-2 mb-0">@ViewBag.TotalPosts</h3>
                <small class="text-muted">Bài viết</small>
            </div>
        </div>
    </div>

    <!-- Card: Danh mục bài viết -->
    <div class="col-md-4 col-lg-2">
        <div class="card text-center" style="border-left: 4px solid #8b5cf6 !important;">
            <div class="card-body py-3">
                <i class="bi bi-tags-fill text-purple" style="font-size: 2rem; color: #8b5cf6;"></i>
                <h3 class="fw-bold mt-2 mb-0">@ViewBag.TotalCategories</h3>
                <small class="text-muted">Danh mục BV</small>
            </div>
        </div>
    </div>

    <!-- Card: Khách hàng -->
    <div class="col-md-4 col-lg-2">
        <div class="card text-center" style="border-left: 4px solid #06b6d4 !important;">
            <div class="card-body py-3">
                <i class="bi bi-people-fill text-info" style="font-size: 2rem;"></i>
                <h3 class="fw-bold mt-2 mb-0">@ViewBag.TotalCustomers</h3>
                <small class="text-muted">Khách hàng</small>
            </div>
        </div>
    </div>

    <!-- Card: Đơn hàng -->
    <div class="col-md-4 col-lg-2">
        <div class="card text-center" style="border-left: 4px solid #ef4444 !important;">
            <div class="card-body py-3">
                <i class="bi bi-receipt-cutoff text-danger" style="font-size: 2rem;"></i>
                <h3 class="fw-bold mt-2 mb-0">@ViewBag.TotalOrders</h3>
                <small class="text-muted">Đơn hàng</small>
            </div>
        </div>
    </div>
</div>

<!-- Bảng dữ liệu -->
<div class="row g-4">
    <!-- 5 Sản phẩm mới nhất -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-primary text-white fw-bold">
                <i class="bi bi-box-seam-fill me-2"></i> 5 Sản phẩm mới nhất
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:50px">Ảnh</th>
                            <th>Tên sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Giá</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.LatestProducts != null)
                        {
                            foreach (var p in ViewBag.LatestProducts)
                            {
                                <tr>
                                    <td>
                                        @if (!string.IsNullOrEmpty(p.ImageUrl))
                                        {
                                            <img src="@p.ImageUrl" style="width:40px; height:40px; object-fit:cover; border-radius:6px;" />
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>@p.Name</td>
                                    <td><span class="badge bg-info">@(p.CategoryProduct != null ? p.CategoryProduct.Name : "—")</span></td>
                                    <td class="text-danger fw-bold">@p.Price.ToString("N0") ₫</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer text-end">
                <a asp-controller="Product" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem tất cả →</a>
            </div>
        </div>
    </div>

    <!-- 5 Bài viết mới nhất -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-warning text-dark fw-bold">
                <i class="bi bi-file-earmark-post-fill me-2"></i> 5 Bài viết mới nhất
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tiêu đề</th>
                            <th>Danh mục</th>
                            <th>Ngày đăng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.LatestPosts != null)
                        {
                            foreach (var post in ViewBag.LatestPosts)
                            {
                                <tr>
                                    <td>@post.Title</td>
                                    <td><span class="badge bg-primary">@(post.Category != null ? post.Category.Name : "—")</span></td>
                                    <td class="text-muted">@post.CreatedDate.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer text-end">
                <a asp-controller="Post" asp-action="Index" class="btn btn-sm btn-outline-warning">Xem tất cả →</a>
            </div>
        </div>
    </div>
</div>
